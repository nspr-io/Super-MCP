{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Node",
    // ignoreDeprecations MUST equal super-mcp's OWN TypeScript major, NOT the parent
    // repo's. super-mcp has its own package-lock.json pinning typescript — currently
    // 5.9.3 (see node_modules/typescript/package.json after `npm ci` in this dir).
    // Valid value for TS 5.x is "5.0"; TS 6.x only accepts "6.0". DO NOT "modernize"
    // this literal by eyeballing the parent repo's TypeScript version — that has
    // caused this line to flip four times in 25 days (regressions 260329, 260424).
    //
    // CLASS-LEVEL FIX (parent repo): the parent repo's `validate:fast` now runs
    // `cd super-mcp && npm install --prefer-offline && npm run build`, so any bad
    // value here (or any other super-mcp build break) fails locally before commit.
    // If you're reading this from inside an agent context, trust that gate — it
    // will tell you the right value empirically. See parent's package.json
    // `validate:super-mcp-build` script.
    //
    // NOTE: modernizing `moduleResolution` to "NodeNext" would eliminate this
    // option entirely, but that migration was attempted on 2026-04-24 and found
    // to require source changes in validator.ts (ajv/ajv-formats CJS interop).
    // See docs/plans/260424_super_mcp_modernize_module_resolution.md for the
    // spike evidence if you're tempted to retry.
    "ignoreDeprecations": "5.0",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}